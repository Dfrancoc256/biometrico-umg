<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="umg.biometrico.ui.CamaraIngresoController"
            prefWidth="1050" prefHeight="720" styleClass="root-pane">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <Button text="← Volver" onAction="#handleVolver" styleClass="btn-back"/>
            <Label text="🚪 Control de Ingreso — Reconocimiento Facial" styleClass="top-title"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="12" styleClass="sidebar" prefWidth="260">
            <Label text="Configuración" styleClass="section-title"/>
            <Label text="Instalación" styleClass="form-label"/>
            <ComboBox fx:id="instalacionCombo" maxWidth="Infinity"/>
            <Label text="Puerta / Acceso" styleClass="form-label"/>
            <ComboBox fx:id="puertaCombo" maxWidth="Infinity"/>
            <HBox spacing="8">
                <Button fx:id="iniciarBtn" text="▶ Iniciar" onAction="#handleIniciarCamara" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="detenerBtn" text="⏹ Detener" onAction="#handleDetener" styleClass="btn-danger"/>
            </HBox>
            <Separator/>
            <ToggleButton fx:id="modoManualToggle" text="📟 Modo Manual (Carnet)" styleClass="btn-outline" maxWidth="Infinity"/>
            <TextField fx:id="carnetManualField" promptText="Número de carnet..."/>
            <Button fx:id="registrarManualBtn" text="✔ Registrar Ingreso" onAction="#handleRegistrarManual" styleClass="btn-secondary" maxWidth="Infinity"/>
            <Separator/>
            <Label fx:id="statusLabel" text="Sistema listo." wrapText="true" styleClass="status-label"/>
            <Label fx:id="ultimoRegistroLabel" text="" wrapText="true" styleClass="success-label"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10" styleClass="camara-center">
            <ImageView fx:id="camaraView" fitWidth="680" fitHeight="500" preserveRatio="true" styleClass="camara-view"/>
            <VBox fx:id="infoPersonaBox" spacing="5" styleClass="info-persona-box" alignment="CENTER">
                <HBox spacing="15" alignment="CENTER">
                    <ImageView fx:id="fotoPersonaView" fitWidth="70" fitHeight="70" preserveRatio="true" styleClass="foto-sm"/>
                    <VBox>
                        <Label fx:id="nombreLabel" text="" styleClass="nombre-grande"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
